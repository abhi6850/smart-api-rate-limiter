# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Option A: connection string (recommended for Netlify — Neon, Supabase, Railway)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option B: individual vars (local dev only)
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=admin
# POSTGRES_PASSWORD=password
# POSTGRES_DB=rate_limiter_db

# ─── Redis ────────────────────────────────────────────────────────────────────
# Option A: connection URL (recommended for Netlify — Upstash, Redis Cloud)
REDIS_URL=rediss://default:password@host:port

# Option B: individual vars (local dev only)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=5000
